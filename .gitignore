# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# OS
.DS_Store

# Large raw data (download with: see README "Get the data").
# Kept out of git because transcript.json is ~40 MB.
data/raw/*.json

# Generated artefacts (re-created by running the pipeline).
data/processed/*.csv
models/*.pkl

# Keep processed/figures folders themselves
!data/processed/.gitkeep
